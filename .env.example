# Currency Symbol
NEXT_PUBLIC_CURRENCY_SYMBOL='$'

# Google Sheets inventory and orders
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SHEET_RANGE=Inventory!A2:C
GOOGLE_ORDERS_SHEET_RANGE=Orders!A:G

# Shared Google OAuth credentials for Drive uploads and Gmail email sending
GOOGLE_ORDER_PROOFS_FOLDER_ID=your_google_drive_folder_id
GOOGLE_OAUTH_CLIENT_ID=your_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_oauth_client_secret
GOOGLE_OAUTH_REFRESH_TOKEN=your_oauth_refresh_token

# Google service account credentials
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Gmail API order confirmation emails
GMAIL_SENDER_EMAIL=orders@yourdomain.com
GMAIL_FROM_NAME="Solar Chapter"
